generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Tab {
  id        String   @id @default(cuid())
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model MembershipPlan {
  id        String   @id @default(cuid())
  name      String
  duration  String
  price     String
  features  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ClassSchedule {
  id        String   @id @default(cuid())
  day       String
  time      String
  className String
  trainer   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Trainer {
  id         String   @id @default(cuid())
  name       String
  specialty  String
  experience String
  bio        String
  imageUrl   String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model Equipment {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String   @default("dumbbell")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model SiteSettings {
  id           String   @id @default("singleton")
  gymName      String   @default("Power Gym")
  tagline      String   @default("Stronger. Every day.")
  phone        String   @default("")
  email        String   @default("")
  address      String   @default("")
  instagramUrl String   @default("")
  facebookUrl  String   @default("")
  twitterUrl   String   @default("")
  youtubeUrl   String   @default("")
  whatsappNum  String   @default("")
  updatedAt    DateTime @updatedAt
}
