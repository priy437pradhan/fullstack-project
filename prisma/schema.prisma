generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Tab {
  id        String   @id @default(cuid())
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model MembershipPlan {
  id        String   @id @default(cuid())
  name      String
  duration  String
  price     String
  features  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ClassSchedule {
  id        String   @id @default(cuid())
  day       String
  time      String
  className String
  trainer   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
